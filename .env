# No environment variables are required to run this app.
# Voice input uses the browser's built-in Web Speech API (no API key needed).

# Supabase — required for multi-device sync (optional; app falls back to localStorage if absent)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
